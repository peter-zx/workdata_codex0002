{
  "name": "daily-log-tool",
  "version": "0.1.0",
  "description": "Responsive daily work log generator with timeline views and one-click copy.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "check": "node --check src/server.js && node --check public/app.js",
    "health": "node -e \"fetch('http://127.0.0.1:'+(process.env.PORT||3000)+'/health').then(r=>{if(!r.ok)process.exit(1);return r.text()}).then(console.log)\""
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
